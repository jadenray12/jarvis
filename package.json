{
  "name": "jarvis",
  "version": "0.1.0",
  "private": true,
  "description": "JARVIS — local-first AI assistant",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev":         "pnpm --filter gateway dev & pnpm --filter ui dev",
    "build":       "pnpm -r build",
    "test":        "pnpm -r test",
    "lint":        "pnpm -r lint",
    "typecheck":   "pnpm -r typecheck",
    "clean":       "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript":     "^5.4.5",
    "@types/node":    "^20.12.7",
    "prettier":       "^3.2.5",
    "eslint":         "^9.1.1"
  }
}