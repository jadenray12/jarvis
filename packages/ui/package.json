{
  "name": "@jarvis/ui",
  "version": "0.1.0",
  "private": true,
  "description": "JARVIS web UI — chat interface and control dashboard",
  "scripts": {
    "dev":       "vite",
    "build":     "tsc && vite build",
    "preview":   "vite preview",
    "test":      "vitest run",
    "lint":      "eslint src",
    "typecheck": "tsc --noEmit",
    "clean":     "rm -rf dist"
  },
  "dependencies": {
    "react":        "^18.3.1",
    "react-dom":    "^18.3.1",
    "d3":           "^7.9.0",
    "pino":         "^9.1.0"
  },
  "devDependencies": {
    "@types/react":       "^18.3.2",
    "@types/react-dom":   "^18.3.0",
    "@types/d3":          "^7.4.3",
    "@types/node":        "^20.12.7",
    "@vitejs/plugin-react":"^4.2.1",
    "typescript":         "^5.4.5",
    "vite":               "^5.2.11",
    "tailwindcss":        "^3.4.3",
    "autoprefixer":       "^10.4.19",
    "postcss":            "^8.4.38",
    "vitest":             "^1.6.0"
  }
}