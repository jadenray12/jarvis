{
  "name": "@jarvis/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "JARVIS WebSocket gateway — control plane",
  "main": "dist/index.js",
  "scripts": {
    "dev":       "ts-node-esm src/index.ts",
    "build":     "tsc",
    "test":      "vitest run",
    "lint":      "eslint src",
    "typecheck": "tsc --noEmit",
    "clean":     "rm -rf dist"
  },
  "dependencies": {
    "ws":       "^8.17.0",
    "bullmq":   "^5.8.3",
    "ioredis":  "^5.3.2",
    "yaml":     "^2.4.2",
    "dotenv":   "^16.4.5",
    "nanoid":   "^5.0.7",
    "pino":     "^9.1.0"
  },
  "devDependencies": {
    "@types/ws":          "^8.5.10",
    "@types/node":        "^20.12.7",
    "typescript":         "^5.4.5",
    "ts-node":            "^10.9.2",
    "vitest":             "^1.6.0",
    "@vitest/coverage-v8":"^1.6.0"
  }
}