# ─────────────────────────────────────────────
# JARVIS Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── Gateway ──────────────────────────────────
JARVIS_WS_HOST=127.0.0.1
JARVIS_WS_PORT=18789
JARVIS_AUTH_TOKEN=changeme_generate_with_openssl_rand_hex_32

# ── Ollama ────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_FALLBACK_MODEL=llama3.2:1b

# ── Memory ────────────────────────────────────
JARVIS_MEMORY_PATH=./data/memory
JARVIS_SQLITE_PATH=./data/memory/cold.db
FAISS_INDEX_PATH=./data/memory/faiss.index

# ── Voice ─────────────────────────────────────
WHISPER_MODEL_PATH=./models/whisper/ggml-base.en.bin
PIPER_MODEL_PATH=./models/piper/en_US-amy-medium.onnx
WAKE_WORD_MODEL=hey_jarvis

# ── Redis (BullMQ) ────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Channels ──────────────────────────────────
# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp (Baileys session path)
WHATSAPP_SESSION_PATH=./data/whatsapp_session

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# ── Skills ────────────────────────────────────
# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Logging ───────────────────────────────────
LOG_LEVEL=info
LOG_PATH=./logs/jarvis.log

# ── Feature Flags ─────────────────────────────
JARVIS_VOICE_ENABLED=true
JARVIS_DISCORD_ENABLED=false
JARVIS_TELEGRAM_ENABLED=false
JARVIS_WHATSAPP_ENABLED=false
JARVIS_SLACK_ENABLED=false
JARVIS_DREAM_MODE_ENABLED=false